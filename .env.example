# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and must NEVER be committed.

# Primary AI provider: Google Gemini (generativelanguage.googleapis.com).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional fallback provider (Imole, OpenAI-compatible Responses API).
# Used automatically only if Gemini is unavailable. Leave blank to disable.
AFRI_API_KEY=
AFRI_API_URL=https://api.imole.app/v1/responses

# Port the Next.js server listens on (defaults to 3000 if unset).
PORT=3001

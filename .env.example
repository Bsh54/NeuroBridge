# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and must NEVER be committed.

# AI provider (OpenAI-compatible Chat Completions endpoint).
# Used for two things: turning selected pictograms into a spoken sentence,
# and powering the caregiver assistant chat.
AFRI_API_KEY=your-api-key-here
AFRI_API_URL=https://your-provider.example.com/v1/chat/completions

# Port the Next.js server listens on (defaults to 3000 if unset).
PORT=3001
